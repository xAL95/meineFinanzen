NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
NEXT_PUBLIC_APPWRITE_DATABASE_ID=
NEXT_PUBLIC_APPWRITE_ACCOUNTS_COLLECTION_ID=accounts
NEXT_PUBLIC_APPWRITE_INCOMES_COLLECTION_ID=incomes
NEXT_PUBLIC_APPWRITE_SUBSCRIPTIONS_COLLECTION_ID=subscriptions
NEXT_PUBLIC_APPWRITE_SUBSCRIPTION_CATEGORIES_COLLECTION_ID=subscription_categories
NEXT_PUBLIC_APPWRITE_BUDGETS_COLLECTION_ID=budgets
NEXT_PUBLIC_APPWRITE_TRANSACTIONS_COLLECTION_ID=transactions

# Kostenlose Open-Banking-Anbindung fuer eigene verknuepfte Konten via Enable Banking.
# Keine NEXT_PUBLIC_ Praefixe verwenden: App-ID und privater Schluessel bleiben serverseitig.
ENABLE_BANKING_APP_ID=
ENABLE_BANKING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
ENABLE_BANKING_REDIRECT_URL=http://localhost:3000/api/bank-connections/enable-banking/callback
ENABLE_BANKING_PSU_TYPE=personal
ENABLE_BANKING_CONSENT_DAYS=90

# Anbieter-Defaults. Revolut nutzt aus Kompatibilitaet auch die alten
# ENABLE_BANKING_ASPSP_NAME/COUNTRY Werte, falls diese gesetzt sind.
ENABLE_BANKING_REVOLUT_ASPSP_NAME=Revolut
ENABLE_BANKING_REVOLUT_ASPSP_COUNTRY=DE
ENABLE_BANKING_VIVID_ASPSP_NAME=Vivid Money
ENABLE_BANKING_VIVID_ASPSP_COUNTRY=DE
